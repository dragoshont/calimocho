#!/usr/bin/env bash
# bin/calimocho-wine — self-contained Wine launcher
#
# Sets every environment variable the Wine engine needs to run
# without depending on the user having Homebrew installed at
# /usr/local. Then execs the real wine binary with the user's args.
#
# Phase 2's Calimocho.app/Contents/Resources/Engine/ ships an
# identical copy of this script. The SwiftUI EngineLauncher just
# `Process.run(this-script, args)` without setting envs itself.
#
# AGENTS rule alignment:
#   - Bakes in WINEDLLOVERRIDES="mscoree,mshtml=" so the Wine Mono /
#     Gecko first-run dialog never appears (.NET / IE not in scope)
#   - Bakes in DYLD_FALLBACK_LIBRARY_PATH pointing at
#     lib/external/runtime/ (where scripts/bundle-deps.sh copies the
#     dylibs Wine dlopens at runtime)
#   - Inherits user-supplied WINEPREFIX (or any wine env var) if set
#
# Don't move this file. The resolver walks up one directory level
# (../) to find the engine root.

set -euo pipefail

# Resolve our own location, following symlinks.
self="$0"
while [[ -L "$self" ]]; do
  link="$(readlink "$self")"
  case "$link" in
    /*) self="$link" ;;
    *)  self="$(cd "$(dirname "$self")" && pwd)/$link" ;;
  esac
done
HERE="$(cd "$(dirname "$self")" && pwd)"
ENGINE="$(cd "$HERE/.." && pwd)"

WINE_BIN="$ENGINE/bin/wine"
RUNTIME_DEPS="$ENGINE/lib/external/runtime"
GPTK_EXTERNAL="$ENGINE/lib/external"

[[ -x "$WINE_BIN" ]] || { echo "calimocho-wine: ERROR engine missing at $WINE_BIN" >&2; exit 3; }

# Skip Wine Mono / Gecko first-prefix prompts. Calimocho's scope
# doesn't include .NET-based Windows apps; SN2 and Steam don't need
# them. Users who DO want .NET can override:
#   WINEDLLOVERRIDES= calimocho-wine ...
# 
# ALSO: Force native (GPTK) d3d11/dxgi for Steam CEF rendering.
# Steam's Chromium Embedded Framework windows render as black with
# Wine's builtin d3d11. CodeWeavers patches + GPTK's D3DMetal.framework
# require "native" to route through D3DMetal instead of Wine's stub.
# This fixes the "black Steam window" bug (SPECS A1.4).
export WINEDLLOVERRIDES="${WINEDLLOVERRIDES-mscoree,mshtml=;d3d11,dxgi=n}"

# Make Wine's runtime dlopen find the bundled libfreetype/libgnutls/
# libdbus/libSDL2/etc. Also include GPTK's own framework dir for
# libd3dshared. Append /usr/lib (system libs like libcups).
# We use DYLD_FALLBACK_LIBRARY_PATH (not DYLD_LIBRARY_PATH) so the
# normal dyld search order applies first — important: if the user
# has a system libfreetype, it wins, and our bundled copy is the
# fallback only for missing-from-system cases. Conservative.
existing="${DYLD_FALLBACK_LIBRARY_PATH-}"
new_path="$RUNTIME_DEPS:$GPTK_EXTERNAL"
if [[ -n "$existing" ]]; then
  export DYLD_FALLBACK_LIBRARY_PATH="$existing:$new_path:/usr/lib"
else
  export DYLD_FALLBACK_LIBRARY_PATH="$new_path:/usr/lib"
fi

# Quiet Wine debug output by default. Users override with WINEDEBUG=...
export WINEDEBUG="${WINEDEBUG-err-all,fixme-all}"

# Vulkan / MoltenVK configuration. Steam's Chromium Embedded Framework
# (CEF) GPU process requires a working Vulkan ICD or it crashes with
# STATUS_BREAKPOINT and the Steam window renders solid black.
# Point the Vulkan loader at our bundled MoltenVK ICD manifest.
export VK_ICD_FILENAMES="${VK_ICD_FILENAMES-$ENGINE/share/vulkan/icd.d/MoltenVK_icd.json}"
export DYLD_FALLBACK_LIBRARY_PATH="$ENGINE/lib/external:$DYLD_FALLBACK_LIBRARY_PATH"

# Apple GPTK environment hints (per GPTK Read Me)
export D3DM_ENABLE_METALFX="${D3DM_ENABLE_METALFX-1}"
export D3DM_SUPPORT_DXR="${D3DM_SUPPORT_DXR-1}"
export ROSETTA_ADVERTISE_AVX="${ROSETTA_ADVERTISE_AVX-1}"

# Wine sync primitives. macOS uses mach-port-based "msync" (CodeWeavers
# patch). esync is Linux-only (eventfd); ntsync requires Linux kernel.
# WINEMSYNC=1 dramatically reduces lock contention in CEF GPU process.
export WINEMSYNC="${WINEMSYNC-1}"
export WINEESYNC="${WINEESYNC-1}"

# MoltenVK tuning for CEF GPU subprocess (mirrors Wineskin / Porting Kit).
# - RESUME_LOST_DEVICE: don't crash when Metal device is lost mid-frame
# - FULL_IMAGE_VIEW_SWIZZLE: handles BGRA → RGBA channel reordering for CEF
# - FAST_MATH_ENABLED=0: matches PK; precision over speed in CEF
export MVK_CONFIG_RESUME_LOST_DEVICE="${MVK_CONFIG_RESUME_LOST_DEVICE-1}"
export MVK_CONFIG_FULL_IMAGE_VIEW_SWIZZLE="${MVK_CONFIG_FULL_IMAGE_VIEW_SWIZZLE-1}"
export MVK_CONFIG_FAST_MATH_ENABLED="${MVK_CONFIG_FAST_MATH_ENABLED-0}"
export MTL_HUD_ENABLED="${MTL_HUD_ENABLED-0}"

# GStreamer plugin path. Wine's winegstreamer.dll calls into the
# bundled GStreamer plugins to decode CEF media (Steam UI's animated
# elements + game intro videos). Without this, CEF media subsystem
# fails to init, which in turn crashes the GPU subprocess.
# (Proton sets GST_PLUGIN_SYSTEM_PATH_1_0, not GST_PLUGIN_PATH.)
if [[ -d "$ENGINE/lib/gstreamer-1.0" ]]; then
  export GST_PLUGIN_SYSTEM_PATH_1_0="${GST_PLUGIN_SYSTEM_PATH_1_0-$ENGINE/lib/gstreamer-1.0}"
fi

# WINE_DISABLE_VULKAN_OPWR: disables "Other Process Window Rendering"
# in Wine's Vulkan layer. This is the path CEF uses to share GPU
# buffers across its sandboxed process boundary. On macOS this is
# the suspected cause of STATUS_BREAKPOINT crashes (per Proton's
# "noopwr" workaround for similar Wayland issues).
export WINE_DISABLE_VULKAN_OPWR="${WINE_DISABLE_VULKAN_OPWR-1}"

exec "$WINE_BIN" "$@"
